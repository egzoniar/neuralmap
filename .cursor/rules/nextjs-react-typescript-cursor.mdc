# Common Patterns in This Codebase

## Custom Hook Pattern
```typescript
// src/hooks/use-feature.tsx
export function useFeature() {
  // Side effects here (useEffect, etc.)
  // Business logic here
  // Return data and callbacks
  return { data, actions };
}
```

## Query Pattern
```typescript
// src/services/resource/queries.ts
export function useGetResource(id: string) {
  const { getAccessTokenSilently } = useAuth0();
  return useQuery({
    queryKey: queryKeys.resource.detail(id),
    queryFn: async () => {
      const token = await getAccessTokenSilently();
      return resourceApi.get(token, id);
    },
    enabled: !!id,
  });
}
```

## Mutation Pattern
```typescript
// src/services/resource/mutations.ts
export function useUpdateResource() {
  const queryClient = useQueryClient();
  const { getAccessTokenSilently } = useAuth0();
  
  return useMutation({
    mutationFn: async (data: ResourceData) => {
      const token = await getAccessTokenSilently();
      return resourceApi.update(token, data);
    },
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: queryKeys.resource.list });
    },
  });
}
```

## Component Pattern
```typescript
// src/components/feature/component.tsx
"use client";

import { ComponentDependency } from "@/components/other/component-dependency";

interface ComponentProps {
  data: string;
  onAction: () => void;
}

export function Component({ data, onAction }: ComponentProps) {
  return (
    <div>
      <ComponentDependency />
    </div>
  );
}
```

