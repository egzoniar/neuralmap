# Patterns

## Query Pattern
```typescript
// services/resource/queries.ts
export function useGetResource(id: string) {
  const { getAccessTokenSilently } = useAuth0();
  return useQuery({
    queryKey: queryKeys.resource.detail(id),
    queryFn: async () => {
      const token = await getAccessTokenSilently();
      return resourceApi.get(token, id);
    },
    enabled: !!id,
  });
}
```

## Mutation Pattern
```typescript
// services/resource/mutations.ts
export function useUpdateResource() {
  const queryClient = useQueryClient();
  const { getAccessTokenSilently } = useAuth0();
  
  return useMutation({
    mutationFn: async (data: ResourceData) => {
      const token = await getAccessTokenSilently();
      return resourceApi.update(token, data);
    },
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: queryKeys.resource.list });
    },
  });
}
```

## Component Pattern
```typescript
"use client";

interface ComponentProps {
  data: string;
  onAction: () => void;
}

export function Component({ data, onAction }: ComponentProps) {
  // NO useEffect here - use custom hooks for side effects
  return <div>{data}</div>;
}
```

## Guard Clause Pattern
Use early returns for cleaner, more maintainable guard clauses:

```typescript
// ✅ GOOD: Early return pattern (explicit, self-documenting)
const handleAction = () => {
  // Guard: Check primary condition
  if (!isEnabled) return;
  
  // Guard: Check state-based condition
  if (isPending) return;
  
  // Guard: Defensive null checks
  if (!requiredData) return;
  
  // Main logic
  performAction(requiredData);
};

// ❌ BAD: Multiple conditions in one if (hard to debug)
const handleAction = () => {
  if (isEnabled && requiredData && !isPending) {
    performAction(requiredData);
  }
};
```

**Benefits:**
- Each guard has clear intent and can be commented separately
- Easier to debug (can log which guard failed)
- More maintainable when conditions change
- Self-documenting code

