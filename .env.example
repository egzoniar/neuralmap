# ===========================================
# Next.js Environment Variables Example
# ===========================================
# Copy this file to .env.local and fill in the values
# Note: NEXT_PUBLIC_* vars are exposed to the browser

# ===========================================
# Database (for Postgres MCP in Cursor)
# ===========================================
# Used by .cursor/mcp.json when running the Postgres MCP server
# DATABASE_URL=postgresql://user:password@localhost:5432/your_database

# ===========================================
# Auth0 Configuration
# ===========================================
# Server-side only (NOT exposed to browser)
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_AUDIENCE=your-auth0-audience

# Client-side (exposed to browser)
NEXT_PUBLIC_AUTH0_DOMAIN=your-domain.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your-auth0-client-id
NEXT_PUBLIC_AUTH0_AUDIENCE=your-auth0-audience
NEXT_PUBLIC_AUTH0_REDIRECT_URI=http://localhost:3000/callback

# ===========================================
# Server URLs
# ===========================================
# Server-side only
SERVER_API_URL=http://localhost:8000

# Client-side (exposed to browser)
NEXT_PUBLIC_SERVER_API_URL=http://localhost:8000
NEXT_PUBLIC_SERVER_WS_URL=ws://localhost:8000
NEXT_PUBLIC_URL=http://localhost:3000

# ===========================================
# Sentry Configuration
# ===========================================
# Client-side (exposed to browser)
NEXT_PUBLIC_SENTRY_ENV=development
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn-url

# Server-side only
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ===========================================
# Vercel – Production (www.neuralmap.co)
# ===========================================
# Set these in: Vercel Dashboard → Project → Settings → Environment Variables
# Scope every variable to "Production" (and optionally "Preview" with dev values).
#
# Required variables and their production values:
#
# NEXT_PUBLIC_SERVER_API_URL   = https://neuralmap-backend.onrender.com/api/v1
# NEXT_PUBLIC_URL              = https://www.neuralmap.co
# NEXT_PUBLIC_AUTH0_DOMAIN     = <same as AUTH0_DOMAIN in backend>
# NEXT_PUBLIC_AUTH0_CLIENT_ID  = <your Auth0 SPA client ID>
# NEXT_PUBLIC_AUTH0_AUDIENCE   = <same as AUTH0_AUDIENCE in backend>
# NEXT_PUBLIC_AUTH0_REDIRECT_URI = https://www.neuralmap.co/callback
# NEXT_PUBLIC_SENTRY_DSN       = <your Sentry DSN>
# NEXT_PUBLIC_SENTRY_ENV       = production
# SENTRY_AUTH_TOKEN            = <Sentry auth token for source map upload>
# SENTRY_ORG                   = <your Sentry org slug>       (optional)
# SENTRY_PROJECT               = <your Sentry project slug>   (optional)
#
# Auth0 Dashboard – add to Allowed Callback URLs, Logout Redirect URLs, Web Origins:
#   https://www.neuralmap.co
#   https://www.neuralmap.co/callback
#
# Paddle: token + environment are served by the backend /billing/config endpoint.
# No Paddle env vars needed on the frontend. Ensure backend checkout creates
# success/cancel/return URLs pointing to https://www.neuralmap.co.
#
# Later: when api.neuralmap.co is set in Render, change NEXT_PUBLIC_SERVER_API_URL
# to https://api.neuralmap.co/api/v1 in the Vercel dashboard and redeploy.
