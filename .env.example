# ===========================================
# Next.js Environment Variables Example
# ===========================================
# Copy this file to .env.local and fill in the values
# Note: NEXT_PUBLIC_* vars are exposed to the browser

# ===========================================
# Auth0 Configuration
# ===========================================
# Server-side only (NOT exposed to browser)
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_AUDIENCE=your-auth0-audience

# Client-side (exposed to browser)
NEXT_PUBLIC_AUTH0_DOMAIN=your-domain.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your-auth0-client-id
NEXT_PUBLIC_AUTH0_AUDIENCE=your-auth0-audience
NEXT_PUBLIC_AUTH0_REDIRECT_URI=http://localhost:3000/callback

# ===========================================
# Server URLs
# ===========================================
# Server-side only
SERVER_API_URL=http://localhost:8000

# Client-side (exposed to browser)
NEXT_PUBLIC_SERVER_API_URL=http://localhost:8000
NEXT_PUBLIC_SERVER_WS_URL=ws://localhost:8000
NEXT_PUBLIC_URL=http://localhost:3000

# ===========================================
# Sentry Configuration
# ===========================================
# Client-side (exposed to browser)
NEXT_PUBLIC_SENTRY_ENV=development
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn-url

# Server-side only
SENTRY_AUTH_TOKEN=your-sentry-auth-token
